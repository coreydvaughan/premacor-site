---
---

<header class="header">
  <!-- ———————————————————————————————————————————————————————————————
       DESKTOP — unchanged layout (md and up)
       ——————————————————————————————————————————————————————————————— -->
  <div class="header-desktop hidden w-full md:flex">
    <div class="header-inner container">
      <a href="/" class="logo">
        <img src="/images/general/premacor-logo.png" alt="Premacor" />
      </a>

      <div class="header-spacer" aria-hidden="true"></div>

      <nav class="nav" aria-label="Primary">
        <a href="/capabilities">Capabilities</a>
        <a href="/industries">Industries</a>
        <a href="/about">About</a>
      </nav>

      <a href="#" class="btn primary">Get In Touch</a>
    </div>
  </div>

  <!-- ———————————————————————————————————————————————————————————————
       MOBILE — logo left, menu toggle right, panel below (below md)
       ——————————————————————————————————————————————————————————————— -->
  <div class="header-mobile flex w-full flex-col md:hidden">
    <div class="header-mobile-bar">
      <a href="/" class="header-mobile-logo">
        <img src="/images/general/premacor-logo.png" alt="Premacor" width="140" height="48" />
      </a>

      <button
        type="button"
        class="header-mobile-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="header-mobile-menu"
        data-mobile-menu-toggle
      >
        <span class="header-mobile-toggle-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M4 7h16M4 12h16M4 17h16"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"></path>
          </svg>
        </span>
      </button>
    </div>

    <nav
      id="header-mobile-menu"
      class="header-mobile-menu"
      aria-label="Primary"
      data-mobile-menu
      hidden
    >
      <button
        type="button"
        class="header-mobile-close"
        aria-label="Close menu"
        data-mobile-menu-close
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
        </svg>
      </button>

      <div class="header-mobile-menu-content">
        <a href="/capabilities">Capabilities</a>
        <a href="/industries">Industries</a>
        <a href="/about">About</a>
        <a href="#" class="header-mobile-menu-cta btn primary">Get In Touch</a>
      </div>
    </nav>
  </div>
</header>

<script>
  (function () {
    const toggle = document.querySelector("[data-mobile-menu-toggle]");
    const menu = document.querySelector("[data-mobile-menu]");
    if (!toggle || !menu) return;

    let isOpen = false;

    function setOpen(next) {
      isOpen = next;
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      menu.hidden = !isOpen;
      document.body.style.overflow = isOpen ? "hidden" : "";
    }

    toggle.addEventListener("click", () => {
      setOpen(!isOpen);
    });

    const closeBtn = document.querySelector("[data-mobile-menu-close]");
    closeBtn?.addEventListener("click", () => {
      setOpen(false);
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        setOpen(false);
      });
    });
  })();
</script>

<style>
  .header {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 10;
    padding-top: clamp(var(--space-5), 3vw, calc(var(--space-1) * 10));
    padding-bottom: calc(var(--space-1) * 5);
  }

  @media (max-width: 767px) {
    .header {
      padding-top: var(--space-3);
      padding-bottom: 0;
    }
  }

  /* ——— Desktop ——— */
  .header-desktop .header-inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    height: 80px;
  }

  .header-spacer {
    flex: 1 1 auto;
    min-width: clamp(var(--space-5), 4vw, calc(var(--space-6) * 1.5));
  }

  .header-desktop .header-inner.container {
    width: 100%;
    max-width: min(1600px, calc(100vw - var(--space-4)));
    margin-left: auto;
    margin-right: auto;
    padding-left: clamp(var(--space-2), 1.25vw, calc(var(--space-1) * 5));
    padding-right: clamp(var(--space-2), 1.25vw, calc(var(--space-1) * 5));
    box-sizing: border-box;
  }

  .header-desktop .logo {
    flex-shrink: 0;
    display: block;
    line-height: 0;
    transform: translateX(-44px);
  }

  .header-desktop .logo img {
    height: 200px;
    width: auto;
    display: block;
  }

  .nav {
    display: flex;
    flex-shrink: 0;
    gap: clamp(var(--space-5), 3vw, calc(var(--space-6) * 1.5));
    margin-right: clamp(var(--space-5), 3vw, calc(var(--space-1) * 10));
  }

  .nav a {
    position: relative;
    display: inline-block;
    font-size: var(--text-nav);
    color: var(--text-nav-muted);
    text-decoration: none;
    padding-bottom: calc(var(--space-1) * 2.4);
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background-color: var(--text-primary);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s ease;
  }

  .nav a:hover {
    opacity: 1;
    color: var(--text-primary);
  }

  .nav a:hover::after {
    transform: scaleX(1);
  }

  .header .btn {
    flex-shrink: 0;
    margin-left: auto;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  /* ——— Mobile ——— */
  .header-mobile-bar {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    min-height: calc(var(--space-1) * 14);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    border-bottom: 1px solid var(--line-subtle);
  }

  .header-mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }

  .header-mobile-toggle:focus-visible {
    outline: 2px solid var(--line-strong);
    outline-offset: 2px;
  }

  .header-mobile-logo {
    display: block;
    flex-shrink: 0;
    line-height: 0;
    min-width: 0;
  }

  .header-mobile-logo img {
    height: 5rem;
    width: auto;
    display: block;
    max-width: 100%;
  }

  /* Full-screen overlay (below md only — parent is md:hidden) */
  .header-mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 1100;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: var(--bg-primary);
    display: flex;
    flex-direction: column;
  }

  .header-mobile-menu[hidden] {
    display: none !important;
  }

  .header-mobile-close {
    position: absolute;
    top: calc(var(--space-1) * 5);
    right: calc(var(--space-1) * 5);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }

  .header-mobile-close:focus-visible {
    outline: 2px solid var(--line-strong);
    outline-offset: 2px;
  }

  .header-mobile-menu-content {
    box-sizing: border-box;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    gap: var(--space-5);
    width: 100%;
    min-height: 0;
    padding: calc(var(--space-1) * 18) var(--space-5) var(--space-6);
    text-align: left;
  }

  .header-mobile-menu-content a:not(.btn) {
    display: block;
    padding: calc(var(--space-1) * 1.4) 0;
    font-size: var(--text-xl);
    color: var(--text-nav-muted);
    text-decoration: none;
    text-align: left;
    transition: color 0.2s ease;
  }

  .header-mobile-menu-content a:not(.btn):hover {
    color: var(--text-primary);
  }

  .header-mobile-menu .header-mobile-menu-cta {
    align-self: flex-start;
    margin-top: var(--space-4);
    text-align: left;
    padding: calc(var(--space-1) * 2.5) calc(var(--space-1) * 5);
    font-size: var(--text-sm);
  }
</style>
