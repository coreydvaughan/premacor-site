<style>
  .social-rail {
    --rail-inset: max(1rem, min(16.67vw, 14rem));
    position: absolute;
    right: var(--rail-inset);
    top: 38vh;
    bottom: auto;
    z-index: 9;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 32px;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease;
  }

  .social-rail.social-rail--visible {
    opacity: 1;
    visibility: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .social-rail {
      transition: none;
    }
  }

  .social-rail__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    min-height: 0;
    width: 100%;
  }

  .social-rail__line {
    flex: 1 1 auto;
    width: 1px;
    min-height: 0;
    align-self: center;
    flex-shrink: 0;
    background: var(--line-subtle);
  }

  .social-rail__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(var(--space-1) * 3.4);
    padding-bottom: max(var(--space-4), env(safe-area-inset-bottom, 0px));
    pointer-events: auto;
  }

  .social-rail__link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-nav-muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .social-rail__link:hover {
    color: var(--text-primary);
    transform: scale(1.08);
  }

  @media (max-width: 1023px) {
    .social-rail {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    function updateSocialRailHeight() {
      var rail = document.querySelector(".social-rail");
      var anchor = document.querySelector(".social-rail-end-anchor");
      if (!rail) return;
      if (!anchor) {
        rail.style.height = "";
        rail.style.bottom = "0";
        return;
      }
      rail.style.bottom = "auto";

      var nav = rail.querySelector(".social-rail__nav");
      var navH = nav ? nav.offsetHeight : 0;
      var railTop = rail.getBoundingClientRect().top;
      var ar = anchor.getBoundingClientRect();
      var anchorMid = ar.top + ar.height / 2;
      var h = Math.round(anchorMid - railTop + navH);
      rail.style.height = Math.max(navH, h) + "px";
    }

    function schedule() {
      updateSocialRailHeight();
      requestAnimationFrame(updateSocialRailHeight);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", schedule);
    } else {
      schedule();
    }

    window.addEventListener("resize", updateSocialRailHeight);
    window.addEventListener("load", updateSocialRailHeight);

    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(updateSocialRailHeight);
    }

    var shell = document.querySelector(".page-shell");
    if (shell && window.ResizeObserver) {
      new ResizeObserver(updateSocialRailHeight).observe(shell);
    }

    function initSocialRailScrollReveal() {
      var rail = document.querySelector(".social-rail");
      if (!rail) return;

      var threshold = 12;

      function reveal() {
        if (rail.classList.contains("social-rail--visible")) return;
        rail.classList.add("social-rail--visible");
        window.removeEventListener("scroll", onScroll);
      }

      function onScroll() {
        if (window.scrollY > threshold) {
          reveal();
        }
      }

      var scrollOpts = { passive: true };

      if (window.scrollY > threshold) {
        reveal();
      } else {
        window.addEventListener("scroll", onScroll, { passive: true });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initSocialRailScrollReveal);
    } else {
      initSocialRailScrollReveal();
    }
  })();
</script>
