---
---

<div
  class="rfq-modal"
  data-rfq-modal
  role="dialog"
  aria-modal="true"
  aria-labelledby="rfq-modal-title"
  aria-hidden="true"
  hidden
>
  <button type="button" class="rfq-modal__backdrop" tabindex="-1" data-rfq-close aria-label="Close dialog"></button>

  <div class="rfq-modal__panel">
    <header class="rfq-modal__header">
      <button type="button" class="rfq-modal__close" data-rfq-close aria-label="Close">
        <svg class="rfq-modal__close-svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
        </svg>
      </button>
    </header>

    <div class="rfq-modal__body">
      <h2 id="rfq-modal-title" class="rfq-modal__title rfq-modal__reveal" style="--rfq-delay: 0ms">
        Request a Quote
      </h2>
      <p class="rfq-modal__lead rfq-modal__reveal" style="--rfq-delay: 75ms">
        Tell us about your project. We’ll follow up with next steps—no obligation.
      </p>

      <form class="rfq-modal__form" id="rfq-form" novalidate>
        <div class="rfq-modal__field rfq-modal__reveal" style="--rfq-delay: 150ms">
          <label class="rfq-modal__label" for="rfq-name">Name</label>
          <input
            class="rfq-modal__input"
            id="rfq-name"
            name="name"
            type="text"
            autocomplete="name"
            required
          />
        </div>

        <div class="rfq-modal__field rfq-modal__reveal" style="--rfq-delay: 225ms">
          <label class="rfq-modal__label" for="rfq-company">Company</label>
          <input
            class="rfq-modal__input"
            id="rfq-company"
            name="company"
            type="text"
            autocomplete="organization"
          />
        </div>

        <div class="rfq-modal__field rfq-modal__reveal" style="--rfq-delay: 300ms">
          <label class="rfq-modal__label" for="rfq-email">Email</label>
          <input
            class="rfq-modal__input"
            id="rfq-email"
            name="email"
            type="email"
            autocomplete="email"
            required
          />
        </div>

        <div class="rfq-modal__field rfq-modal__reveal" style="--rfq-delay: 375ms">
          <label class="rfq-modal__label" for="rfq-service">Service type</label>
          <select class="rfq-modal__input rfq-modal__select" id="rfq-service" name="service" required>
            <option value="" disabled selected>Select a service</option>
            <option value="cnc-machining">CNC Machining</option>
            <option value="fabrication">Metal forming & fabrication</option>
            <option value="injection-molding">Injection molding</option>
            <option value="engineering">Production engineering</option>
            <option value="other">Other / not sure</option>
          </select>
        </div>

        <div class="rfq-modal__field rfq-modal__reveal" style="--rfq-delay: 450ms">
          <label class="rfq-modal__label" for="rfq-description">Description</label>
          <textarea
            class="rfq-modal__input rfq-modal__textarea"
            id="rfq-description"
            name="description"
            rows="4"
            placeholder="Part quantities, materials, timeline…"
          ></textarea>
        </div>

        <div class="rfq-modal__field rfq-modal__reveal" style="--rfq-delay: 525ms">
          <label class="rfq-modal__label" for="rfq-file">Attach files (optional)</label>
          <input
            class="rfq-modal__file"
            id="rfq-file"
            name="file"
            type="file"
            multiple
          />
        </div>

        <div class="rfq-modal__actions rfq-modal__reveal" style="--rfq-delay: 600ms">
          <button type="submit" class="btn primary rfq-modal__submit">Submit request</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    const root = document.querySelector("[data-rfq-modal]");
    if (!root || !(root instanceof HTMLElement)) return;

    const panel = root.querySelector(".rfq-modal__panel");
    let lastFocus = null;

    function open() {
      lastFocus = document.activeElement;
      root.hidden = false;
      root.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          root.classList.add("is-open");
          const closeBtn = root.querySelector(".rfq-modal__close");
          if (closeBtn instanceof HTMLElement) closeBtn.focus();
        });
      });
    }

    function close() {
      root.classList.remove("is-open");
      root.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      window.setTimeout(function () {
        root.hidden = true;
        if (lastFocus instanceof HTMLElement) lastFocus.focus();
      }, 300);
    }

    document.querySelectorAll("[data-rfq-open]").forEach(function (el) {
      el.addEventListener("click", function (e) {
        e.preventDefault();
        open();
      });
    });

    root.querySelectorAll("[data-rfq-close]").forEach(function (el) {
      el.addEventListener("click", function () {
        close();
      });
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && root.classList.contains("is-open")) {
        close();
      }
    });

    const form = root.querySelector("#rfq-form");
    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", function (e) {
        e.preventDefault();
      });
    }
  })();
</script>

<style>
  .rfq-modal {
    --rfq-motion-duration: 300ms;
    --rfq-motion-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --rfq-stagger-shift: var(--motion-cap-panel-shift-in);

    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity var(--rfq-motion-duration) var(--rfq-motion-ease),
      visibility var(--rfq-motion-duration) var(--rfq-motion-ease);
  }

  .rfq-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .rfq-modal__backdrop {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--overlay-scrim);
    cursor: pointer;
  }

  .rfq-modal__panel {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
    max-height: 100vh;
    max-height: 100dvh;
    background: var(--bg-surface);
    border-top: 1px solid var(--line-subtle);
    box-shadow: 0 calc(var(--space-2) * -1) var(--space-6) var(--shadow-medium);
    transform: translateY(100%);
    transition: transform var(--rfq-motion-duration) var(--rfq-motion-ease);
  }

  .rfq-modal.is-open .rfq-modal__panel {
    transform: translateY(0);
  }

  .rfq-modal__header {
    position: sticky;
    top: 0;
    z-index: 2;
    flex-shrink: 0;
    display: flex;
    justify-content: flex-end;
    padding: var(--space-3) var(--space-4) 0;
    background: linear-gradient(to bottom, var(--bg-surface) 70%, transparent);
  }

  .rfq-modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--space-4) * 2.75);
    height: calc(var(--space-4) * 2.75);
    margin: 0;
    padding: 0;
    border: none;
    border-radius: var(--radius-inset-soft);
    background: color-mix(in srgb, var(--text-primary) 8%, transparent);
    color: var(--text-primary);
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .rfq-modal__close:hover {
    background: color-mix(in srgb, var(--text-primary) 14%, transparent);
  }

  .rfq-modal__close:focus-visible {
    outline: 2px solid var(--line-strong);
    outline-offset: 2px;
  }

  .rfq-modal__close-svg {
    display: block;
  }

  .rfq-modal__body {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    padding: 0 var(--space-4) var(--space-6);
    -webkit-overflow-scrolling: touch;
  }

  .rfq-modal__title {
    margin: 0 0 var(--space-3);
    font-size: var(--text-h2);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .rfq-modal__lead {
    margin: 0 0 var(--space-5);
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 52ch;
  }

  .rfq-modal__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: min(36rem, 100%);
  }

  .rfq-modal__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .rfq-modal__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
  }

  .rfq-modal__input,
  .rfq-modal__select {
    width: 100%;
    box-sizing: border-box;
    margin: 0;
    padding: var(--space-3) var(--space-4);
    font-family: inherit;
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    color: var(--text-primary);
    background: var(--bg-primary);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-inset-soft);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .rfq-modal__input::placeholder {
    color: var(--text-muted);
  }

  .rfq-modal__input:focus-visible,
  .rfq-modal__select:focus-visible {
    outline: none;
    border-color: var(--line-active);
    box-shadow: 0 0 0 1px var(--line-active);
  }

  .rfq-modal__textarea {
    min-height: calc(var(--space-6) * 4);
    resize: vertical;
  }

  .rfq-modal__file {
    width: 100%;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .rfq-modal__file::file-selector-button {
    margin-right: var(--space-3);
    padding: var(--space-2) var(--space-4);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--text-primary) 10%, transparent);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-inset-soft);
    cursor: pointer;
  }

  .rfq-modal__actions {
    padding-top: var(--space-2);
  }

  .rfq-modal__submit {
    width: 100%;
  }

  /* Staggered reveal (runs when .is-open) */
  .rfq-modal__reveal {
    opacity: 0;
    transform: translateY(var(--rfq-stagger-shift));
    transition:
      opacity 0.4s var(--rfq-motion-ease),
      transform 0.4s var(--rfq-motion-ease);
    transition-delay: var(--rfq-delay, 0ms);
  }

  .rfq-modal.is-open .rfq-modal__reveal {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .rfq-modal {
      transition: opacity 0.15s ease;
    }

    .rfq-modal__panel {
      transition: transform 0.2s ease;
    }

    .rfq-modal__reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
