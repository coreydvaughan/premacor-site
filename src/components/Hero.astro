    position: absolute;
    inset: 0;
    background: var(--gradient-hero-overlay);
  }

  /* CONTENT — custom wrapper replaces global .container constraints */
  .hero-wrapper {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: min(1600px, calc(100vw - var(--space-4)));
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--hero-wrapper-padding-x);
    padding-right: var(--hero-wrapper-padding-x);
    box-sizing: border-box;
  }

  .hero-content {
    max-width: 880px;
    display: flex;
    flex-direction: column;
  }

  .hero-content h1 {
    margin-bottom: var(--hero-h1-margin-bottom);
  }

  .hero-rotating-line {
    display: inline;
    white-space: nowrap;
  }

  .hero-rotating {
    display: inline;
    transition: opacity 1.15s ease;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.18em;
    text-decoration-color: var(--text-decoration-muted);
  }

  .hero-content h2.hero-tagline {
    margin-bottom: var(--hero-tagline-margin-bottom);
    max-width: 52ch;
  }

  .hero-actions {
    margin-top: var(--hero-actions-margin-top);
  }
</style>

