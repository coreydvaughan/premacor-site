<script>
  (function () {
    const words = ["Consistency", "Precision", "Durability", "Performance", "Excellence"];

    function init() {
      const el = document.getElementById("hero-rotating-word");
      if (!el) return;

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        el.textContent = words[0];
        return;
      }

      const fadeMs = 1150;
      const holdMs = 4000;
      let i = 0;

      el.textContent = words[0];
      el.style.opacity = "1";

      function tick() {
        window.setTimeout(function () {
          el.style.opacity = "0";
          window.setTimeout(function () {
            i = (i + 1) % words.length;
            el.textContent = words[i];
            el.style.opacity = "1";
            tick();
          }, fadeMs);
        }, holdMs);
      }

      tick();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>